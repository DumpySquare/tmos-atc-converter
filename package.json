{
  "name": "tmos-atc-converter",
  "version": "1.0.2",
  "description": "Convert F5 TMOS configuration to AS3 Classic and Declarative Onboarding declarations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && npm run copy-vendor",
    "copy-vendor": "node scripts/copy-vendor.js",
    "build:watch": "tsc --watch",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "cross-env TS_NODE_PROJECT=tsconfig.test.json mocha --require ts-node/register 'test/**/*.test.ts' 'test/**/*spec.ts' 'test/**/*spec.js' --recursive --timeout 30000",
    "test:js": "mocha test --recursive --timeout 30000",
    "test:upstream": "mocha test/upstream --recursive --timeout 30000",
    "test:coverage": "c8 --reporter=text --reporter=html --all --src=src npm test",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json"
  },
  "keywords": [
    "f5",
    "bigip",
    "tmos",
    "as3",
    "as3-classic",
    "declarative-onboarding",
    "config-converter"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DumpySquare/tmos-atc-converter"
  },
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "ajv": "^8.17.1",
    "deepmerge": "^4.3.1",
    "lodash": "^4.17.21",
    "tar": "^7.4.3",
    "uuid": "^13.0.0",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/lodash": "^4.17.21",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.2",
    "@types/sinon": "^21.0.0",
    "c8": "^10.1.3",
    "chai": "^4.5.0",
    "chai-as-promised": "^8.0.0",
    "cross-env": "^10.1.0",
    "mocha": "^10.8.2",
    "nunjucks": "^3.2.4",
    "sinon": "^21.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
